			<IconSymbol>NACI</IconSymbol>
			<Size>
				<X>0.2</X>
				<Y>0.2</Y>
				<Z>0.2</Z>
			</Size>
			<Mass>0.1</Mass>
			<Volume>1</Volume>
			<Model>Models\Items\AquaSaltPowderR.mwm</Model>
			<PhysicalMaterial>Metal</PhysicalMaterial>
			<MaxIntegrity>30</MaxIntegrity>
			<DropProbability>0.5</DropProbability>
			<Health>18</Health>
			<CanPlayerOrder>false</CanPlayerOrder>
		</Component>

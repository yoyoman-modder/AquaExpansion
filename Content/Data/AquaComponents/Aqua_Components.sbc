			<Id>
				<TypeId>Component</TypeId>
				<SubtypeId>AquaSaltPowderR</SubtypeId>
			</Id>
			<DisplayName>Salt Powder(Refined)</DisplayName>
			<Description>
				Finely processed salt for advanced applications.
				Used in crafting Salt Cells and energy systems.
			</Description>

				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_reefFish3" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_reefFish4" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_reefFish5" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_reefFish7" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_reefFish8" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_reefFish12" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_reefFish14" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_reefFish16" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_reefFish17" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_reefFish20" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_yellowTang" />
				<Entry Type="ConsumableItem" Subtype="AquaFishdRaw_tinyYellowFish" />
			</PushConstraint>
		</EntityComponent>
		<EntityComponent xsi:type="MyObjectBuilder_ConveyorEndpointComponentDefinition">
			<Id>
				<TypeId>ConveyorEndpointComponent</TypeId>
				<SubtypeId>UnderwaterFishingStation</SubtypeId>

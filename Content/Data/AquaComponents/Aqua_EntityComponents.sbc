		<!-- Region Cnoveoir-->
		<EntityComponent xsi:type="MyObjectBuilder_ConveyorEndpointComponentDefinition">
			<Id>
				<TypeId>ConveyorEndpointComponent</TypeId>
				<SubtypeId>UnderwaterFarmPlot</SubtypeId>
			</Id>
			<PullConstraint Whitelist="true" Description="Seaweed" Icon="Textures\GUI\Icons\Cubes\FarmPlot.dds">
				<Entry Type="Component" Subtype="AquaSeaweedSpores_Green" />
				<Entry Type="Component" Subtype="AquaSeaweedSpores_Brown" />
				<Entry Type="Component" Subtype="AquaSeaweedSpores_Red" />
			</PullConstraint>
			<PushConstraint Whitelist="true" Description="Seaweed" Icon="Textures\GUI\Icons\Cubes\FarmPlot.dds">
				<Entry Type="ConsumableItem" Subtype="AquaSeaweedRaw_Green" />
				<Entry Type="ConsumableItem" Subtype="AquaSeaweedRaw_Brown" />
				<Entry Type="ConsumableItem" Subtype="AquaSeaweedRaw_Red" />
			</PushConstraint>
		</EntityComponent>

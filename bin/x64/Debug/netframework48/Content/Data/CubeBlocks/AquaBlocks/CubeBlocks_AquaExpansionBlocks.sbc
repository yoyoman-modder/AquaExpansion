<?xml version="1.0" encoding="utf-8"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
	<CubeBlocks>
		<!-- Region AquaExpansion Main blocks-->
		<Definition xsi:type="MyObjectBuilder_FunctionalBlockDefinition">
			<Id>
				<TypeId>FunctionalBlock</TypeId>
				<SubtypeId>LargeBlockUnderWaterTurbneB</SubtypeId>
			</Id>
			<DisplayName>Underwater Turbine Basic</DisplayName>
			<Description>Generates power from water currents and wave motion</Description>
			<Icon>Textures\GUI\Icons\Cubes\WindTurbine.dds</Icon>
			<Icon>Textures\GUI\Icons\Cubes\AquaExpansionLogo.dds</Icon>
			<CubeSize>Large</CubeSize>
			<GuiVisible>false</GuiVisible>
			<PlaceDecals>false</PlaceDecals>
			<ResearchCost>5</ResearchCost>
			<BlockTopology>TriangleMesh</BlockTopology>
			<Size x="3" y="3" z="3" />
			<Center x="1" y="0" z="1" />
			<ModelOffset x="0" y="0" z="0" />
			<Model>Models\Cubes\Large\WindTurbine.mwm</Model>
			<Components>
				<Component Subtype="InteriorPlate" Count="20" />
				<Component Subtype="Motor" Count="20" />
				<Component Subtype="Construction" Count="40" />
				<Component Subtype="Girder" Count="50" />
				<Component Subtype="Computer" Count="5" />
				<Component Subtype="InteriorPlate" Count="40" />
				<Component Subtype="SteelPlate" Count="20" />
			</Components>
			<CriticalComponent Subtype="Computer" Index="0" />
			<MountPoints>
				<MountPoint Side="Bottom" StartX="1" StartY="1" EndX="2" EndY="2" Default="true" />
			</MountPoints>
			<MirroringY>Z</MirroringY>
			<BuildProgressModels>
				<Model BuildPercentUpperBound="0.33" File="Models\Cubes\Large\WindTurbine_Construction1.mwm" />
				<Model BuildPercentUpperBound="0.66" File="Models\Cubes\Large\WindTurbine_Construction2.mwm" />
				<Model BuildPercentUpperBound="1.00" File="Models\Cubes\Large\WindTurbine_Construction3.mwm" />
			</BuildProgressModels>
			<!--<BlockPairName>LargeBlockUnderWaterTurbneB</BlockPairName>-->
			<EdgeType>Light</EdgeType>
			<BuildTimeSeconds>30</BuildTimeSeconds>
			<DamageEffectId>214</DamageEffectId>
			<ActionSound>ArcBlockWindTurbine</ActionSound>
			<DamageEffectName>Damage_Electrical_Damaged</DamageEffectName>
			<DamagedSound>ParticleElectrical</DamagedSound>
			<DestroySound>ParticleWeapExpl</DestroySound>
			<EmissiveColorPreset>Default</EmissiveColorPreset>
			<IsAirTight>false</IsAirTight>
			<ResourceSourceGroup>SolarPanels</ResourceSourceGroup>
			<VoxelPlacement>
				<StaticMode>
					<PlacementMode>OutsideVoxel</PlacementMode>
				</StaticMode>
				<DynamicMode>
					<PlacementMode>OutsideVoxel</PlacementMode>
				</DynamicMode>
			</VoxelPlacement>
			<PCU>55</PCU>
			<TargetingGroups>
				<string>PowerSystems</string>
			</TargetingGroups>
		</Definition>
		<Definition xsi:type="MyObjectBuilder_FunctionalBlockDefinition">
			<Id>
				<TypeId>FunctionalBlock</TypeId>
				<SubtypeId>LargeBlockUnderWaterTurbneS</SubtypeId>
			</Id>
			<DisplayName>Underwater Turbine Standart</DisplayName>
			<Description>Generates power from water currents and wave motion</Description>
			<Icon>Textures\GUI\Icons\Cubes\WindTurbineReskin_Large.dds</Icon>
			<Icon>Textures\GUI\Icons\Cubes\AquaExpansionLogo.dds</Icon>
			<CubeSize>Large</CubeSize>
			<GuiVisible>false</GuiVisible>
			<PlaceDecals>false</PlaceDecals>
			<BlockTopology>TriangleMesh</BlockTopology>
			<Size x="5" y="5" z="5" />
			<Center x="2" y="0" z="2" />
			<!-- The Offset is there as the Base model had to be placed in the world origin 0,0,0. If the Base of the block was offseted like usual, it couldn't be built properly and had a lot of broken triangles-->
			<ModelOffset x="0" y="-6.25" z="0" />
			<Model>Models\Cubes\Large\WindTurbineBaseReskin.mwm</Model>
			<Components>
				<Component Subtype="InteriorPlate" Count="25" />
				<Component Subtype="Motor" Count="25" />
				<Component Subtype="Construction" Count="45" />
				<Component Subtype="Girder" Count="55" />
				<Component Subtype="Computer" Count="8" />
				<Component Subtype="InteriorPlate" Count="45" />
				<Component Subtype="SteelPlate" Count="25" />
			</Components>
			<CriticalComponent Subtype="Computer" Index="0" />
			<MountPoints>
				<MountPoint Side="Bottom" StartX="2" StartY="2" EndX="3" EndY="3" Default="true" />
			</MountPoints>
			<MirroringY>X</MirroringY>
			<MirroringX>Y</MirroringX>
			<BuildProgressModels>
				<Model BuildPercentUpperBound="0.33" File="Models\Cubes\Large\WindTurbineReskin_Construction_1.mwm" />
				<Model BuildPercentUpperBound="0.66" File="Models\Cubes\Large\WindTurbineReskin_Construction_2.mwm" />
				<Model BuildPercentUpperBound="1.00" File="Models\Cubes\Large\WindTurbineReskin_Construction_3.mwm" />
			</BuildProgressModels>
			<!--<BlockPairName>LargeBlockUnderWaterTurbneS</BlockPairName>-->
			<EdgeType>Light</EdgeType>
			<BuildTimeSeconds>30</BuildTimeSeconds>
			<DamageEffectId>214</DamageEffectId>
			<ActionSound>ArcBlockWindTurbine</ActionSound>
			<DamageEffectName>Damage_Electrical_Damaged</DamageEffectName>
			<DamagedSound>ParticleElectrical</DamagedSound>
			<DestroySound>ParticleWeapExpl</DestroySound>
			<ResourceSourceGroup>SolarPanels</ResourceSourceGroup>
			<EmissiveColorPreset>Default</EmissiveColorPreset>
			<IsAirTight>false</IsAirTight>
			<VoxelPlacement>
				<StaticMode>
					<PlacementMode>OutsideVoxel</PlacementMode>
				</StaticMode>
				<DynamicMode>
					<PlacementMode>OutsideVoxel</PlacementMode>
				</DynamicMode>
			</VoxelPlacement>
			<PCU>55</PCU>
			<TargetingGroups>
				<string>PowerSystems</string>
			</TargetingGroups>
			<DLC>DecorativeBlocks3</DLC>
		</Definition>
		<Definition xsi:type="MyObjectBuilder_RefineryDefinition">
			<Id>
				<TypeId>Refinery</TypeId>
				<SubtypeId>SaltExtractor</SubtypeId>
			</Id>
			<DisplayName>Salt Extractor</DisplayName>
			<Icon>Textures\GUI\Icons\Cubes\Blastfurnace.dds</Icon>
			<Icon>Textures\GUI\Icons\Cubes\AquaExpansionLogo.dds</Icon>
			<Description>Extracts salt from ice and seawater</Description>
			<CubeSize>Large</CubeSize>
			<GuiVisible>false</GuiVisible>
			<BlockTopology>TriangleMesh</BlockTopology>
			<Size x="1" y="2" z="1" />
			<ModelOffset x="0" y="0" z="0" />
			<Model>Models\Cubes\large\SaltExtractor.mwm</Model>
			<Components>
				<Component Subtype="SteelPlate" Count="100" />
				<Component Subtype="Construction" Count="20" />
				<Component Subtype="Motor" Count="10" />
				<Component Subtype="Computer" Count="10" />
				<Component Subtype="SteelPlate" Count="20" />
			</Components>
			<CriticalComponent Subtype="Computer" Index="0" />
			<MountPoints>
				<MountPoint Side="Bottom" StartX="0" StartY="0" EndX="1" EndY="1" Default="true" />
				<MountPoint Side="Left" StartX="0" StartY="0" EndX="1" EndY="1" />
				<MountPoint Side="Right" StartX="0" StartY="0" EndX="1" EndY="1" />
				<MountPoint Side="Back" StartX="0" StartY="0" EndX="1" EndY="1" />
				<MountPoint Side="Front" StartX="0" StartY="0" EndX="1" EndY="2" />
			</MountPoints>
			<BuildProgressModels>
				<Model BuildPercentUpperBound="0.33" File="Models\Cubes\Large\BasicRefineryConstruction_1.mwm" />
				<Model BuildPercentUpperBound="0.66" File="Models\Cubes\Large\BasicRefineryConstruction_2.mwm" />
				<Model BuildPercentUpperBound="1.00" File="Models\Cubes\Large\BasicRefineryConstruction_3.mwm" />
			</BuildProgressModels>
			<BlockPairName>SaltExtractor</BlockPairName>
			<EdgeType>Light</EdgeType>
			<BuildTimeSeconds>40</BuildTimeSeconds>
			<ResourceSinkGroup>Factory</ResourceSinkGroup>
			<InventoryMaxVolume>4</InventoryMaxVolume>
			<InventorySize>
				<X>2</X>
				<Y>2</Y>
				<Z>2</Z>
			</InventorySize>
			<InventoryFillFactorMin>0.3</InventoryFillFactorMin>
			<InventoryFillFactorMax>0.6</InventoryFillFactorMax>
			<StandbyPowerConsumption>0.001</StandbyPowerConsumption>
			<OperationalPowerConsumption>0.33</OperationalPowerConsumption>
			<BlueprintClasses>
				<Class>SaltGenerator</Class>
			</BlueprintClasses>
			<RefineSpeed>0.65</RefineSpeed>
			<MaterialEfficiency>0.7</MaterialEfficiency>
			<DamageEffectName>Damage_Electrical_Damaged</DamageEffectName>
			<DamagedSound>ParticleElectrical</DamagedSound>
			<PrimarySound>BlockRafinery</PrimarySound>
			<ActionSound>BlockRafineryProcess</ActionSound>
			<EmissiveColorPreset>Default</EmissiveColorPreset>
			<DestroyEffect>BlockDestroyedExplosion_Large</DestroyEffect>
			<DestroySound>ParticleWeapExpl</DestroySound>
			<OreAmountPerPullRequest>2000</OreAmountPerPullRequest>
			<PCU>75</PCU>
			<TieredUpdateTimes>
				<unsignedInt>60</unsignedInt>
				<unsignedInt>120</unsignedInt>
				<unsignedInt>240</unsignedInt>
			</TieredUpdateTimes>
			<AllowSelfPulling>false</AllowSelfPulling>
		</Definition>
		<Definition xsi:type="MyObjectBuilder_BatteryBlockDefinition">
			<Id>
				<TypeId>BatteryBlock</TypeId>
				<SubtypeId>LargeBlockSaltBattery</SubtypeId>
			</Id>
			<DisplayName>Salt Battery</DisplayName>
			<Icon>Textures\GUI\Icons\Cubes\BatteryReskin.dds</Icon>
			<Icon>Textures\GUI\Icons\Cubes\AquaExpansionLogo.dds</Icon>
			<Description>Stores energy using saline electrochemical cells</Description>
			<CubeSize>Large</CubeSize>
			<BlockTopology>TriangleMesh</BlockTopology>
			<Size x="1" y="1" z="1" />
			<ModelOffset x="0" y="0" z="0" />
			<Model>Models\Cubes\Large\BatteryReskin.mwm</Model>
			<Components>
				<Component Subtype="SteelPlate" Count="20" />
				<Component Subtype="Construction" Count="15" />
				<Component Subtype="SaltPowerCell" Count="70">
					<DeconstructId>
						<TypeId>Ore</TypeId>
						<SubtypeId>Scrap</SubtypeId>
					</DeconstructId>
				</Component>
				<Component Subtype="Computer" Count="28" />
				<Component Subtype="Construction" Count="25" />
				<Component Subtype="SteelPlate" Count="60" />
			</Components>
			<CriticalComponent Subtype="SaltPowerCell" Index="0" />
			<BuildProgressModels>
				<Model BuildPercentUpperBound="0.33" File="Models\Cubes\Large\BatteryReskinConstruction_1.mwm" />
				<Model BuildPercentUpperBound="0.66" File="Models\Cubes\Large\BatteryReskinConstruction_2.mwm" />
				<Model BuildPercentUpperBound="1.00" File="Models\Cubes\Large\BatteryReskinConstruction_3.mwm" />
			</BuildProgressModels>
			<EdgeType>Light</EdgeType>
			<BuildTimeSeconds>40</BuildTimeSeconds>
			<ResourceSourceGroup>Battery</ResourceSourceGroup>
			<MaxPowerOutput>10</MaxPowerOutput>
			<ResourceSinkGroup>BatteryBlock</ResourceSinkGroup>
			<RequiredPowerInput>10</RequiredPowerInput>
			<AdaptibleInput>true</AdaptibleInput>
			<MaxStoredPower>2</MaxStoredPower>
			<InitialStoredPowerRatio>0.3</InitialStoredPowerRatio>
			<RechargeMultiplier>0.7</RechargeMultiplier>
			<InventorySize>
				<X>1</X>
				<Y>1</Y>
				<Z>1</Z>
			</InventorySize>
			<Public>true</Public>
			<DamageEffectName>Damage_Electrical_Damaged</DamageEffectName>
			<DamagedSound>ParticleElectrical</DamagedSound>
			<EmissiveColorPreset>Extended</EmissiveColorPreset>
			<DestroyEffect>BlockDestroyedExplosion_Large</DestroyEffect>
			<DestroySound>ParticleWeapExpl</DestroySound>
			<PCU>15</PCU>
			<IsAirTight>true</IsAirTight>
			<MirroringY>X</MirroringY>
			<TargetingGroups>
				<string>PowerSystems</string>
			</TargetingGroups>
			<DLC>Warfare2</DLC>
		</Definition>
		<Definition xsi:type="MyObjectBuilder_BatteryBlockDefinition">
